# Copy to ".env" and fill in. See docs/SETUP.md for a step-by-step walkthrough.
#
# IMPORTANT: docker compose reads this via `env_file`, which does NOT reliably
# strip trailing inline comments. Keep every comment on its OWN line and put
# nothing after a value — otherwise the comment becomes part of the value.

# ---- Auth ----
# Refresh token from ring-auth-cli (2FA). This is ONLY the first-start seed:
# once the worker runs it persists + rotates the token in /data/secrets, and
# the persisted file then wins over this value. Generate it at first start —
# not in advance. See docs/SETUP.md.
RING_REFRESH_TOKEN=
RING_CONTROL_CENTER_NAME=local-nvr

# ---- Paths (container-internal; mapped onto SATA in docker-compose.yml) ----
DATA_MEDIA_DIR=/data/media
DATA_DB_PATH=/data/db/ring.db
TOKEN_FILE=/data/secrets/refresh-token
HEARTBEAT_FILE=/data/db/.heartbeat

# ---- Recording (M2) ----
# CLIP_SECONDS: Decision B. Configurable. Battery-friendly default.
CLIP_SECONDS=30
# RECORD_SNAPSHOT: KORREKTUR 1 — getSnapshot is best-effort only on battery
# cams; keep off.
RECORD_SNAPSHOT=false

# ---- Operation ----
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info
TZ=Europe/Berlin
# DEVICE_FILTER: optional camera id(s) or name substring, comma-separated.
# Leave EMPTY to watch all cameras. Do not put a comment after the value.
DEVICE_FILTER=
