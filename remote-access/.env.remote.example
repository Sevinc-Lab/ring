# Konfiguration der firmenfreien Fernzugriffs-Schiene. Kopieren nach .env:
#   cp .env.remote.example .env

# Deine DuckDNS-Domain (komplett), z.B. meinring.duckdns.org
DASHBOARD_DOMAIN=meinring.duckdns.org

# Nur der Teil VOR .duckdns.org (für den DuckDNS-Updater), z.B. meinring
DUCKDNS_SUBDOMAIN=meinring

# Dein DuckDNS-Token (von https://www.duckdns.org nach dem Login oben)
DUCKDNS_TOKEN=dein-duckdns-token

# Passwort für die WireGuard-Web-UI (http://<host>:51821) — frei wählbar
WG_UI_PASSWORD=ein-gutes-passwort
